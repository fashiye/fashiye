### 4.3 账号加密工具（AES-256-CBC）

```python
# app/core/crypto.py
import base64
import os
from Crypto.Cipher import AES
from Crypto.Util.Padding import pad, unpad
from app.core.config import settings

class AccountCrypto:
    def __init__(self):
        self.key = base64.b64decode(settings.AES_SECRET_KEY)  # 从环境变量读取，BASE64编码的32字节密钥
        self.iv = base64.b64decode(settings.AES_IV)           # 16字节IV

    def encrypt(self, plain_text: str) -> str:
        cipher = AES.new(self.key, AES.MODE_CBC, self.iv)
        padded_data = pad(plain_text.encode('utf-8'), AES.block_size)
        encrypted_bytes = cipher.encrypt(padded_data)
        return base64.b64encode(encrypted_bytes).decode('utf-8')

    def decrypt(self, encrypted_text: str) -> str:
        encrypted_bytes = base64.b64decode(encrypted_text)
        cipher = AES.new(self.key, AES.MODE_CBC, self.iv)
        decrypted_padded = cipher.decrypt(encrypted_bytes)
        return unpad(decrypted_padded, AES.block_size).decode('utf-8')
```

### 4.4 订单服务（含乐观锁接单）

```python
# app/services/order_service.py
from sqlalchemy.ext.asyncio import AsyncSession
from sqlalchemy import select, update
from app.models.order import Order, OrderLog
from app.models.user import User, Handler
from app.schemas.order import OrderCreate, OrderStatusAction
from app.core.exceptions import BusinessError
from app.utils.order_no_generator import generate_order_no
from app.services.price_calculator import calculate_price
from app.core.crypto import AccountCrypto
import json

crypto = AccountCrypto()

class OrderService:
    @staticmethod
    async def create_order(db: AsyncSession, user: User, order_data: OrderCreate):
        # 1. 校验游戏存在且启用
        # 2. 根据类型计算价格
        if order_data.type == "standard":
            # 查询项目
            project = await db.get(Project, order_data.project_id)
            if not project or project.status != 1:
                raise BusinessError("项目不存在或已禁用")
            price_info = calculate_price(project, order_data.quantity)
            custom_name = None
            custom_description = None
            custom_price = None
        else:  # custom
            price_info = {
                'unit_price': order_data.custom_price,
                'total': order_data.custom_price,
                'quantity': 1
            }
            project_id = None
            custom_name = order_data.custom_name
            custom_description = order_data.custom_description
            custom_price = order_data.custom_price

        # 3. 加密账号信息
        encrypted_account = crypto.encrypt(order_data.account_info)

        # 4. 创建订单
        order = Order(
            order_no=generate_order_no(),
            user_id=user.id,
            game_id=order_data.gameId,
            project_id=project_id,
            custom_name=custom_name,
            custom_description=custom_description,
            custom_price=custom_price,
            quantity=price_info['quantity'],
            unit_price=price_info['unit_price'],
            total_amount=price_info['total'],
            status='pending',
            account_info=encrypted_account,
            requirements=order_data.requirements,
            attachments=order_data.attachments
        )
        db.add(order)
        await db.flush()

        # 5. 记录日志
        log = OrderLog(
            order_id=order.id,
            operator_type='user',
            operator_id=user.id,
            action='create',
            new_status='pending'
        )
        db.add(log)
        await db.commit()
        await db.refresh(order)
        return order

    @staticmethod
    async def accept_order(db: AsyncSession, order_id: int, handler: Handler):
        """接单 - 乐观锁实现"""
        # 使用 UPDATE ... WHERE 乐观锁
        stmt = (
            update(Order)
            .where(Order.id == order_id, Order.status == 'pending')
            .values(status='accepted', handler_id=handler.id, accepted_at=func.now())
            .returning(Order)
        )
        result = await db.execute(stmt)
        updated_order = result.scalar_one_or_none()
        if not updated_order:
            raise BusinessError("订单已被抢单或状态已变更", code=409)

        # 记录日志
        log = OrderLog(
            order_id=order_id,
            operator_type='handler',
            operator_id=handler.id,
            action='accept',
            old_status='pending',
            new_status='accepted'
        )
        db.add(log)
        await db.commit()
        await db.refresh(updated_order)
        return updated_order
```

